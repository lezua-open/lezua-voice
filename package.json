{
  "name": "voicetranscribe",
  "version": "1.0.0",
  "description": "Press-and-hold voice transcription with real-time waveform",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.lezua.voicetranscribe",
    "productName": "VoiceTranscribe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.19"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0"
  }
}
